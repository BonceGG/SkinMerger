<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.StackPane?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="io.github.boncegg.skinmergermc.SkinMergerController"
      style="-fx-background-color: #0a0a0a;">

    <!-- izquierda -->
    <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="10"
          style="-fx-background-color: #0e0e0e; -fx-border-color: transparent #1e1e1e transparent transparent; -fx-border-width: 0 1 0 0;">
        <padding>
            <Insets top="20" bottom="20" left="16" right="16"/>
        </padding>

        <Label text="S K I N S"
               maxWidth="Infinity"
               style="-fx-text-fill: #aaaaaa;
                      -fx-font-size: 10;
                      -fx-font-weight: bold;
                      -fx-letter-spacing: 2;
                      -fx-padding: 0 0 8 0;
                      -fx-border-color: transparent transparent #1e1e1e transparent;
                      -fx-border-width: 0 0 1 0;"/>

        <ListView fx:id="skinListView"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color: transparent;
                         -fx-control-inner-background: #111111;
                         -fx-font-size: 12;
                         -fx-font-family: 'Consolas';
                         -fx-text-fill: #cccccc;
                         -fx-border-color: #1e1e1e;
                         -fx-border-width: 1;
                         -fx-border-radius: 3;
                         -fx-background-radius: 3;"/>
    </VBox>

    <!-- centro -->
    <VBox spacing="10" alignment="TOP_CENTER" prefWidth="190"
          style="-fx-background-color: #0e0e0e; -fx-border-color: transparent #1e1e1e transparent transparent; -fx-border-width: 0 1 0 0;">
        <padding>
            <Insets top="20" bottom="20" left="16" right="16"/>
        </padding>

        <Label text="A C C E S S O R I E S"
               maxWidth="Infinity"
               style="-fx-text-fill: #aaaaaa;
                      -fx-font-size: 10;
                      -fx-font-weight: bold;
                      -fx-padding: 0 0 8 0;
                      -fx-border-color: transparent transparent #1e1e1e transparent;
                      -fx-border-width: 0 0 1 0;"/>

        <ListView fx:id="accesoryListView"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color: transparent;
                         -fx-control-inner-background: #111111;
                         -fx-font-size: 12;
                         -fx-font-family: 'Consolas';
                         -fx-text-fill: #cccccc;
                         -fx-border-color: #1e1e1e;
                         -fx-border-width: 1;
                         -fx-border-radius: 3;
                         -fx-background-radius: 3;"/>

        <Button text="Select Folder"
                onAction="#onSelectAccesory"
                maxWidth="Infinity"
                style="-fx-background-color: #161616;
                       -fx-border-color: #2a2a2a;
                       -fx-border-width: 1;
                       -fx-text-fill: #888888;
                       -fx-font-size: 11;
                       -fx-padding: 7 10;
                       -fx-border-radius: 3;
                       -fx-cursor: hand;"
                onMouseEntered="#onButtonHover"
                onMouseExited="#onButtonExit"/>
    </VBox>

    <!-- derecha -->
    <VBox spacing="12" alignment="TOP_RIGHT" prefWidth="260"
          style="-fx-background-color: #0c0c0c;">
        <padding>
            <Insets bottom="20" left="16" right="16" top="20"/>
        </padding>

        <!-- Preview -->
        <VBox alignment="CENTER"
              style="-fx-background-color: #111111;
                     -fx-border-color: #1e1e1e;
                     -fx-border-width: 1;
                     -fx-border-radius: 4;">
            <Label text="P R E V I E W"
                   maxWidth="Infinity"
                   style="-fx-text-fill: #555555;
                          -fx-font-size: 9;
                          -fx-font-weight: bold;
                          -fx-padding: 6 10 6 10;
                          -fx-border-color: transparent transparent #1e1e1e transparent;
                          -fx-border-width: 0 0 1 0;"/>
            <StackPane style="-fx-padding: 12;">
                <ImageView fx:id="previewImageView"
                           fitWidth="112" fitHeight="112"
                           preserveRatio="true"
                           style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 8, 0, 0, 2);"/>
            </StackPane>
        </VBox>

        <!-- Log -->
        <TextArea fx:id="logArea"
                  editable="false"
                  wrapText="true"
                  VBox.vgrow="ALWAYS"
                  prefWidth="228"
                  maxWidth="Infinity"
                  style="-fx-control-inner-background: #080808;
                         -fx-text-fill: #fefefe;
                         -fx-font-size: 14;
                         -fx-border-color: #1e1e1e;
                         -fx-border-width: 1;
                         -fx-border-radius: 3;
                         -fx-font-family: Monaco;
                         -fx-highlight-fill: #2a2a2a;"/>

        <VBox spacing="3" alignment="CENTER_LEFT">
            <Label fx:id="selectBase"   style="-fx-text-fill: #3a3a3a; -fx-font-size: 10; -fx-font-family: Consolas;"/>
            <Label fx:id="selectSkins"  style="-fx-text-fill: #3a3a3a; -fx-font-size: 10; -fx-font-family: Consolas;"/>
            <Label fx:id="selectFolder" style="-fx-text-fill: #3a3a3a; -fx-font-size: 10; -fx-font-family: Consolas;"/>
        </VBox>

        <!-- Botones -->
        <HBox spacing="5">
            <Button text="Base"     onAction="#onSelectBase"   HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #141414; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 6 8; -fx-border-radius: 3; -fx-cursor: hand;" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <Button text="Skins"    onAction="#onSelectSkins"  HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #141414; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 6 8; -fx-border-radius: 3; -fx-cursor: hand;" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <Button text="Delete"   onAction="#onDeleteSkin"   HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #141414; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 6 8; -fx-border-radius: 3; -fx-cursor: hand;" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <!--<Button text="Carpeta"  onAction="#onSelectOutput" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #141414; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 6 8; -fx-border-radius: 3; -fx-cursor: hand;" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
        --></HBox>
        <HBox spacing="5">
            <Button text="Save"  onAction="#onSaveSkins"    HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #141414; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 6 8; -fx-border-radius: 3; -fx-cursor: hand;" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <Button text="Original" onAction="#onResetSkin"    HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #141414; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 6 8; -fx-border-radius: 3; -fx-cursor: hand;" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <Button text="Reset"   onAction="#onResetAll"   HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #141414; -fx-border-color: #2a2a2a; -fx-border-width: 1; -fx-text-fill: #cccccc; -fx-font-size: 11; -fx-padding: 6 8; -fx-border-radius: 3; -fx-cursor: hand;" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
        </HBox>

        <!-- Merge -->
        <Button text="MERGE" onAction="#onMergeSkin" maxWidth="Infinity"
                style="-fx-background-color: #181818;
                       -fx-border-color: #333333;
                       -fx-border-width: 1;
                       -fx-text-fill: #eeeeee;
                       -fx-font-size: 12;
                       -fx-font-weight: bold;
                       -fx-padding: 10 12;
                       -fx-border-radius: 3;
                       -fx-cursor: hand;
                       -fx-letter-spacing: 1;"
                onMouseEntered="#onButtonHover"
                onMouseExited="#onButtonExit"/>
    </VBox>
</HBox>